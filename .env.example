# Tienda ALOHA - Environment Configuration
# Copy to .env and adjust values

FLASK_APP=run.py
FLASK_ENV=production          # development | production
FLASK_DEBUG=0                 # 1 for dev, 0 for prod

# Database (use 4 slashes for absolute path in Docker: sqlite:////app/...)
DATABASE_URL=sqlite:////app/instance/tiendita.db

# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me

# Server binding
APP_HOST=0.0.0.0
APP_PORT=5000

# Set to false if behind a reverse proxy handling SSL (e.g. Cloudflare/nginx)
SESSION_COOKIE_SECURE=false
